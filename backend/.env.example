# ─── Business Central Connection ───
# URL base de OData de tu empresa (sin el nombre del Web Service al final)
BC_ODATA_URL=https://api.businesscentral.dynamics.com/v2.0/7bd617d8-1150-4669-b1fe-3fddd532dd57/Production/ODataV4/Company('Global%20Food%20Link%20S.L')

# Tipo de autenticacion: "bearer" para OAuth2, "ntlm" para on-premise
BC_AUTH_TYPE=bearer

# Token OAuth2 (si usas bearer)
BC_TOKEN=tu_token_aqui

# Credenciales NTLM (si usas on-premise)
BC_USER=
BC_PASSWORD=

# ─── Nombres de Web Services publicados en BC ───
# Estos deben coincidir EXACTAMENTE con el "Nombre del servicio" en Servicios Web de BC
WS_PALLETS=AITPalletsList
WS_SALES_HEADER=SalesOrder
WS_SALES_LINE=SalesLinePrueba
WS_ITEM_UOM=ItemUnitOfMeasure
WS_PROD_TRANSLATE=ProductTranslation
WS_ITEM_REF=ItemReference

# ─── Cache ───
# Minutos que se cachean los datos de BC (evita llamadas excesivas)
CACHE_MINUTES=5
